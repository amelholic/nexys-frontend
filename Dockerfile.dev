# Dev image: Vite + HMR. Source is bind-mounted at runtime; anonymous volumes keep
# container node_modules and .svelte-kit from being replaced by the host mount.
FROM node:24-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
