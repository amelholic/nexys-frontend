{
	"name": "nexys-frontend",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"brief:manifest": "node scripts/brief-jsx-manifest.mjs",
		"predev": "npm run brief:manifest",
		"prebuild": "npm run brief:manifest",
		"dev": "vite dev",
		"build": "vite build",
		"build:amplify": "SVELTEKIT_ADAPTER=amplify vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint \"src/**/*.ts\"",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@sveltejs/kit": "^2.56.0",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.5.0",
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.8.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.1.0",
		"@types/node": "^22.0.0",
		"amplify-adapter": "^1.3.0",
		"bits-ui": "^2.17.0",
		"eslint": "^9.0.0",
		"mode-watcher": "^1.1.0",
		"svelte": "^5.46.0",
		"svelte-check": "^4.0.0",
		"svelte-sonner": "^1.1.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.58.2",
		"vite": "^8.0.0",
		"vitest": "^4.1.0"
	}
}
